                    </div>
                </div>
                <!-- Product 3 -->
                <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
                    <img src="https://images.unsplash.com/photo-1484101403633-562f891dc89a?q=80&w=1200&auto=format&fit=crop" class="h-72 w-full object-cover">
                    <div class="p-6">
                        <h4 class="text-lg font-semibold text-gray-800">Modern Wall Piece</h4>
