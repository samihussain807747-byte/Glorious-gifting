    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Glorious Gifting - Luxury Home Decor</title>
    <!-- Tailwind CSS for styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        html { scroll-behavior: smooth; }
        body { font-family: 'Georgia', serif; background-color: #fdfbf7; }
    </style>
</head>
<body class="text-gray-800 selection:bg-[#0a2e26] selection:text-white">

    <!-- HEADER / NAVIGATION -->
    <header class="sticky top-0 z-50 bg-[#fdfbf7]/90 backdrop-blur-md border-b border-gray-100 px-6 py-4 shadow-sm">
