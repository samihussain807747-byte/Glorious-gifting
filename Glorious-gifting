            <div class="relative rounded-3xl overflow-hidden shadow-lg group h-[450px]">
                <img src="https://images.unsplash.com/photo-1494526585095-c41746248156?q=80&w=1200&auto=format&fit=crop" class="h-full w-full object-cover">
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent flex items-end p-8">
                    <div>
                        <h4 class="text-white text-3xl font-bold">Table Decor</h4>
                        <p class="text-gray-200 mt-2 font-light text-sm tracking-wider uppercase">Luxury centerpieces</p>
                    </div>
                </div>
            </div>
            <!-- Card 2 -->
            <div class="relative rounded-3xl overflow-hidden shadow-lg group h-[450px]">
                <img src="https://images.unsplash.com/photo-1484154218962-a197022b5858?q=80&w=1200&auto=format&fit=crop" class="h-full w-full object-cover">
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent flex items-end p-8">
