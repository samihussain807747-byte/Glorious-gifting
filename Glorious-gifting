            <nav class="hidden md:flex space-x-8 text-sm font-medium tracking-wider uppercase text-gray-600">
                <a href="#home" class="hover:text-[#0a2e26] transition-colors">Home</a>
                <a href="#collections" class="hover:text-[#0a2e26] transition-colors">Collections</a>
                <a href="#products" class="hover:text-[#0a2e26] transition-colors">Products</a>
                <a href="#contact" class="hover:text-[#0a2e26] transition-colors">Contact</a>
            </nav>
        </div>
    </header>

    <!-- HERO SECTION -->
    <section id="home" class="relative h-[85vh] flex items-center justify-center bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=1600&auto=format&fit=crop')">
        <div class="absolute inset-0 bg-black/40"></div>
        <div class="relative z-10 text-center text-white px-6">
            <h2 class="text-5xl md:text-7xl font-bold mb-6 leading-tight">Luxury Home Decor</h2>
            <p class="text-lg md:text-2xl mb-8 max-w-2xl mx-auto text-gray-200 font-light">Premium decorative items crafted to elevate your living space and gifting experience.</p>
            <a href="#products" class="inline-block bg-white text-[#0a2e26] px-8 py-4 rounded-full font-semibold shadow-lg hover:bg-[#0a2e26] hover:text-white transform hover:-translate-y-0.5 transition duration-300">Shop The Collection</a>
