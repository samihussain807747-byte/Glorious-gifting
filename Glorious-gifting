                </div>
                <!-- Product 4 -->
                <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
                    <img src="https://images.unsplash.com/photo-1493666438817-866a91353ca9?q=80&w=1200&auto=format&fit=crop" class="h-72 w-full object-cover">
                    <div class="p-6">
                        <h4 class="text-lg font-semibold text-gray-800">Premium Candle Holder</h4>
                        <p class="text-[#0a2e26] font-medium mt-1 text-lg">₹999</p>
                        <button class="mt-5 w-full bg-[#0a2e26] text-white py-3 rounded-xl font-medium">Add to Cart</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

